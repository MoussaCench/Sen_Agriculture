# ============================================================

# Fichiers / dossiers à ne jamais pousser
bin/
obj/
.vs/
packages/
*.user
*.suo
*.cache
*.log
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
*.aps
*.ncb
*.opensdf
*.sdf
*.VC.db
*.VC.VC.opendb
Error/
SqlServerTypes/
UpgradeLog.htm

# Ignorer tout le reste du projet sauf les fichiers listés ci-dessous
/*
!/.gitignore
!/.gitignore.membre1
!/.gitignore.membre2
!/.gitignore.membre3

# Solution et projet (partagés)
!/AppSenAgriculture.sln
!/AppSenAgriculture.csproj
!/App.config
!/App.config.example

# Partie Membre 2 : MDI principal + Helper (Utils, Crypto)
!/frmMDI.cs
